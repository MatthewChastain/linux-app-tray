<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.linuxapptray.Settings" path="/org/linuxapptray/Settings/">
    <key name="position" type="s">
      <default>'bottom'</default>
      <summary>Tray position</summary>
      <description>Screen edge where the tray is shown.</description>
    </key>
    <key name="max-visible-icons" type="i">
      <default>6</default>
      <summary>Maximum visible icons</summary>
      <description>Number of icons shown before using the overflow popup.</description>
    </key>
    <key name="always-show-all-icons" type="b">
      <default>false</default>
      <summary>Always show all icons</summary>
      <description>Disable overflow and keep every icon visible.</description>
    </key>
    <key name="icon-size" type="i">
      <default>20</default>
      <summary>Icon size</summary>
      <description>Preferred icon size in pixels.</description>
    </key>
  </schema>
</schemalist>
